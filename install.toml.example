[tools.claude]
enabled = true
instructions = "~/.claude/CLAUDE.md"
skills = "~/.claude/skills"
agents = "~/.claude/agents"
hooks = "~/.claude/hooks"

[tools.codex]
enabled = true
instructions = "~/.codex/AGENTS.md"
skills = "~/.agents/skills"

[tools.gemini]
enabled = false
instructions = "~/.gemini/GEMINI.md"
skills = "~/.agents/skills"  # cross-tool standard; verify Gemini's home path before enabling

[tools.antigravity]
enabled = false
# Antigravity is GEMINI.md-primary — it does NOT auto-read AGENTS.md/CLAUDE.md, and it
# shares the hardcoded ~/.gemini/GEMINI.md path with Gemini CLI (enable only one to own it).
# Global skills live in ~/.gemini/config/skills — NOT ~/.agents/skills, which Antigravity
# reads only at workspace scope (<project>/.agents/skills/).
instructions = "~/.gemini/GEMINI.md"
skills = "~/.gemini/config/skills"

[tools.omp]
enabled = false  # requires the omp (Oh My Pi) binary and its own ~/.omp/agent setup first
instructions = "~/.omp/agent/AGENTS.md"
skills = "~/.agents/skills"  # omp's own docs call this the canonical OMP-native cross-tool location
